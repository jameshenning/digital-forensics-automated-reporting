# ─── Forensic data — NEVER commit ────────────────────────────────
# SQLite databases may contain case data, PII, chain-of-custody records.
*.db
*.db-shm
*.db-wal

# ─── Secrets ──────────────────────────────────────────────────────
.env
.env.local
instance/
local_config/

# Release signing private key — NEVER commit
# (generated by `cargo tauri signer generate -p`, stored outside the repo
# at %USERPROFILE%\.dfars-release\; this rule is a belt-and-braces guard)
*.pem
release_private_key*
tauri-signing-key*

# ─── Rust / Cargo ────────────────────────────────────────────────
target/
**/target/
*.pdb

# ─── Node / npm ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Vite / bundled frontend output ──────────────────────────────
dist/
dist-ssr/
*.local

# ─── TanStack Router generated route tree (regenerated on build) ─
src/routeTree.gen.ts

# ─── Logs ────────────────────────────────────────────────────────
logs/
*.log

# ─── Editor / IDE ────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS junk ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
$RECYCLE.BIN/
ehthumbs.db
Desktop.ini

# ─── Claude Code session/agent state ─────────────────────────────
.claude/

# ─── Stray MSVC object files from ad-hoc compile tests ───────────
*.obj
